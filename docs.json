{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "EcoWestern Support",
  "colors": {
    "primary": "#086d00",
    "light": "#086d00",
    "dark": "#086d00"
  },
  "favicon": {
    "light": "/images/ecowesternicon(1).png",
    "dark": "/images/ecoclover.png"
  },
  "navigation": {
    "products": [
      {
        "product": "General",
        "pages": [
          "home"
        ]
      },
      {
        "product": "Azura",
        "pages": [
          "getting-started",
          "artifacts",
          "image-and-file-attachments",
          "managing-conversations",
          "memory",
          "omnibox-and-commands",
          "tips-and-tricks"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/ecowesternicon(1).png",
    "dark": "/images/ecoclover.png",
    "href": "https://ecowestern.net"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "background": {
    "decoration": "windows"
  },
  "appearance": {
    "default": "system"
  },
  "thumbnails": {
    "appearance": "dark"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true
  },
  "icons": {
    "library": "lucide"
  },
  "search": {
    "prompt": "Ask Azura..."
  },
  "interaction": {
    "drilldown": true
  },
  "seo": {
    "indexing": "navigable"
  },
  "fonts": {
    "family": "Google Sans"
  }
}
